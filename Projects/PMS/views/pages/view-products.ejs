<%- include('../partials/header.ejs') %>
      <!-- ============================================================== -->
      <!-- Page wrapper  -->
      <!-- ============================================================== -->
      <div class="page-wrapper">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="page-breadcrumb">
          <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
              <h4 class="page-title">View Products</h4>
              <div class="ms-auto text-end">
                <nav aria-label="breadcrumb">
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin">Home</a></li>
                    <li class="breadcrumb-item active" aria-current="page">
                      View Products
                    </li>
                  </ol>
                </nav>
              </div>
            </div>
          </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="container-fluid">
          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">All Products</h5>
                    <a href="/admin/add-product" class="btn btn-primary btn-sm">
                      <i class="mdi mdi-plus"></i> Add New Product
                    </a>
                  </div>

                  <!-- Alert area -->
                  <div id="alertArea"></div>

                </div>
                <table class="table table-hover" id="productsTable">
                  <thead>
                    <tr>
                      <th scope="col">#</th>
                      <th scope="col">Image</th>
                      <th scope="col">Name</th>
                      <th scope="col">Price</th>
                      <th scope="col">Category</th>
                      <th scope="col">Sub Category</th>
                      <th scope="col">Extra Category</th>
                      <th scope="col">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="productsBody">
                    <% if(products && products.length > 0) { %>
                      <% products.forEach((product, index) => { %>
                        <tr>
                          <th scope="row"><%= index + 1 %></th>
                          <td>
                            <% if(product.image) { %>
                              <img src="/<%= product.image %>" alt="<%= product.name %>" style="width:50px; height:50px; object-fit:cover; border-radius:5px;" onerror="this.src='/assets/images/logo-icon.png'">
                            <% } else { %>
                              <span class="text-muted">No image</span>
                            <% } %>
                          </td>
                          <td><%= product.name || '-' %></td>
                          <td>₹<%= product.price || 0 %></td>
                          <td><%= product.category ? product.category.name : '-' %></td>
                          <td><%= product.subcategory ? product.subcategory.name : '-' %></td>
                          <td><%= product.extracategory ? product.extracategory.name : '-' %></td>
                          <td>
                            <button class="btn btn-warning btn-sm" onclick="editProduct('<%= product._id %>')">
                              <i class="mdi mdi-pencil"></i> Edit
                            </button>
                            <button class="btn btn-danger btn-sm" onclick="deleteProduct('<%= product._id %>')">
                              <i class="mdi mdi-delete"></i> Delete
                            </button>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="8" class="text-center">No products found. <a href="/admin/add-product">Add one now!</a></td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

<!-- Edit Product Modal -->
<div class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editProductModalLabel">Edit Product</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editProductForm" enctype="multipart/form-data">
        <div class="modal-body">
          <input type="hidden" id="editProductId" />
          <div class="form-group mb-3">
            <label for="editName" class="form-label">Product Name</label>
            <input type="text" class="form-control" id="editName" name="name" required />
          </div>
          <div class="form-group mb-3">
            <label for="editDescription" class="form-label">Description</label>
            <input type="text" class="form-control" id="editDescription" name="description" required />
          </div>
          <div class="form-group mb-3">
            <label for="editPrice" class="form-label">Price</label>
            <input type="number" class="form-control" id="editPrice" name="price" required />
          </div>
          <div class="form-group mb-3">
            <label for="editImage" class="form-label">Image (leave empty to keep current)</label>
            <input type="file" class="form-control" id="editImage" name="image" accept="image/*" />
          </div>
          <div class="form-group mb-3">
            <label for="editCategory" class="form-label">Category</label>
            <select class="form-control" id="editCategory" name="category" required>
              <option value="">Select Category</option>
            </select>
          </div>
          <div class="form-group mb-3">
            <label for="editSubCategory" class="form-label">Sub Category</label>
            <select class="form-control" id="editSubCategory" name="subcategory" required>
              <option value="">Select Sub Category</option>
            </select>
          </div>
          <div class="form-group mb-3">
            <label for="editExtraCategory" class="form-label">Extra Category</label>
            <select class="form-control" id="editExtraCategory" name="extracategory" required>
              <option value="">Select Extra Category</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary" id="updateBtn">Update Product</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  let allCategories = <%- JSON.stringify(categories || []) %>;
  let allSubCategories = <%- JSON.stringify(subCategories || []) %>;
  let allExtraCategories = <%- JSON.stringify(extraCategories || []) %>;
  let allProducts = <%- JSON.stringify(products || []) %>;

  function editProduct(id) {
    const product = allProducts.find(p => p._id === id);
    if (!product) return;

        document.getElementById('editProductId').value = product._id;
        document.getElementById('editName').value = product.name || '';
        document.getElementById('editDescription').value = product.description || '';
        document.getElementById('editPrice').value = product.price || '';

        // Populate category dropdowns
        populateEditSelect('editCategory', allCategories, product.category ? product.category._id : '');
        populateEditSelect('editSubCategory', allSubCategories, product.subcategory ? product.subcategory._id : '');
        populateEditSelect('editExtraCategory', allExtraCategories, product.extracategory ? product.extracategory._id : '');

        const modal = new bootstrap.Modal(document.getElementById('editProductModal'));
        modal.show();
  }

  function populateEditSelect(selectId, data, selectedId) {
    const select = document.getElementById(selectId);
    select.innerHTML = '<option value="">Select</option>';
    data.forEach(item => {
      const option = document.createElement('option');
      option.value = item._id;
      option.textContent = item.name;
      if (item._id === selectedId) option.selected = true;
      select.appendChild(option);
    });
  }

  // Handle edit form submission
  document.getElementById('editProductForm').addEventListener('submit', async function (e) {
    e.preventDefault();

    const id = document.getElementById('editProductId').value;
    const updateBtn = document.getElementById('updateBtn');
    updateBtn.disabled = true;
    updateBtn.textContent = 'Updating...';

    const formData = new FormData(this);

    try {
      const response = await fetch('/api/product/' + id, {
        method: 'PATCH',
        body: formData
      });

      const result = await response.json();
      if (result.error) {
        showAlert('danger', 'Error: ' + result.error);
      } else {
        showAlert('success', 'Product updated successfully!');
        const modal = bootstrap.Modal.getInstance(document.getElementById('editProductModal'));
        modal.hide();
        window.location.reload();
      }
    } catch (error) {
      showAlert('danger', 'Error updating product: ' + error.message);
    } finally {
      updateBtn.disabled = false;
      updateBtn.textContent = 'Update Product';
    }
  });

  async function deleteProduct(id) {
    if (!confirm('Are you sure you want to delete this product?')) return;

    try {
      const response = await fetch('/api/product/' + id, {
        method: 'DELETE'
      });

      const result = await response.json();
      if (result.error) {
        showAlert('danger', 'Error: ' + result.error);
      } else {
        showAlert('success', 'Product deleted successfully!');
        window.location.reload();
      }
    } catch (error) {
      showAlert('danger', 'Error deleting product: ' + error.message);
    }
  }

  function showAlert(type, message) {
    const alertArea = document.getElementById('alertArea');
    alertArea.innerHTML = `
      <div class="alert alert-${type} alert-dismissible fade show" role="alert">
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    `;
    setTimeout(() => { alertArea.innerHTML = ''; }, 4000);
  }
</script>

       <%- include('../partials/footer.ejs') %>
