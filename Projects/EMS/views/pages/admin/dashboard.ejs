<%- include('../../partials/head.ejs', { title: 'Dashboard', extraCss: '' }) %>

    <%- include('../../partials/sidebar.ejs') %>
    <%- include('../../partials/header.ejs') %>

    <!--! Main Content -->
    <main class="nxl-container">
        <div class="nxl-content">
            <!-- Page Header -->
            <div class="page-header">
                <div class="page-header-left d-flex align-items-center">
                    <div class="page-header-title">
                        <h5 class="m-b-10">Dashboard</h5>
                    </div>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item">Dashboard</li>
                    </ul>
                </div>
            </div>

            <!-- Main Content -->
            <div class="main-content">
                <div class="row">
                    <!-- Welcome Card -->
                    <div class="col-xxl-12">
                        <div class="card stretch stretch-full">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <h5 class="fw-bold mb-1">
                                            Welcome back, 
                                            <% if (typeof admin !== 'undefined' && admin) { %>
                                                <%= admin.name || 'Administrator' %>
                                            <% } else { %>
                                                Administrator
                                            <% } %>! 👋
                                        </h5>
                                        <p class="fs-12 text-muted">Here's what's happening with your employee management system today.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Stats Cards -->
                    <div class="col-xxl-3 col-md-6">
                        <div class="card stretch stretch-full">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-text avatar-lg bg-soft-primary text-primary rounded">
                                            <i class="feather-users fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold fs-12 text-muted">Total Employees</div>
                                            <h4 class="mt-1 fw-bolder"><%= typeof employeeCount !== 'undefined' ? employeeCount : 0 %></h4>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xxl-3 col-md-6">
                        <div class="card stretch stretch-full">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-text avatar-lg bg-soft-success text-success rounded">
                                            <i class="feather-check-square fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold fs-12 text-muted">Total Tasks</div>
                                            <h4 class="mt-1 fw-bolder"><%= typeof taskCount !== 'undefined' ? taskCount : 0 %></h4>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xxl-3 col-md-6">
                        <div class="card stretch stretch-full">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-text avatar-lg bg-soft-warning text-warning rounded">
                                            <i class="feather-user-plus fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold fs-12 text-muted">Add Employee</div>
                                            <a href="/admin/createEmployee" class="mt-1 fw-bold fs-13 text-primary">Go →</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xxl-3 col-md-6">
                        <div class="card stretch stretch-full">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-text avatar-lg bg-soft-danger text-danger rounded">
                                            <i class="feather-plus-square fs-4"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold fs-12 text-muted">Add Task</div>
                                            <a href="/admin/addTask" class="mt-1 fw-bold fs-13 text-primary">Go →</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="row">
                    <div class="col-xxl-6">
                        <div class="card stretch stretch-full">
                            <div class="card-header">
                                <h5 class="card-title">Quick Actions</h5>
                            </div>
                            <div class="card-body">
                                <div class="d-flex flex-wrap gap-2">
                                    <a href="/admin/createEmployee" class="btn btn-primary">
                                        <i class="feather-user-plus me-2"></i>Add Employee
                                    </a>
                                    <a href="/admin/viewEmployees" class="btn btn-info">
                                        <i class="feather-users me-2"></i>View Employees
                                    </a>
                                    <a href="/admin/addTask" class="btn btn-success">
                                        <i class="feather-plus-square me-2"></i>Add Task
                                    </a>
                                    <a href="/admin/viewTasks" class="btn btn-warning">
                                        <i class="feather-check-square me-2"></i>View Tasks
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xxl-6">
                        <div class="card stretch stretch-full">
                            <div class="card-header">
                                <h5 class="card-title">System Info</h5>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled mb-0">
                                    <li class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                        <span class="text-muted">Role</span>
                                        <span class="badge bg-primary">Admin</span>
                                    </li>
                                    <li class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                        <span class="text-muted">Version</span>
                                        <span class="fw-bold">1.0.0</span>
                                    </li>
                                    <li class="d-flex align-items-center justify-content-between py-2">
                                        <span class="text-muted">Status</span>
                                        <span class="badge bg-success">Active</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <footer class="footer">
                <p class="fs-11 text-muted fw-medium text-uppercase mb-0 copyright">
                    <span>Copyright ©</span>
                    <script>document.write(new Date().getFullYear())</script>
                </p>
                <div class="d-flex align-items-center gap-4">
                    <a href="javascript:void(0);" class="fs-11 fw-semibold text-uppercase">Help</a>
                    <a href="javascript:void(0);" class="fs-11 fw-semibold text-uppercase">Terms</a>
                    <a href="javascript:void(0);" class="fs-11 fw-semibold text-uppercase">Privacy</a>
                </div>
            </footer>
        </div>
    </main>

<%- include('../../partials/footer.ejs', { extraJs: '' }) %>
