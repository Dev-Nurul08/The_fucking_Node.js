<%- include('../../partials/head.ejs', { title: 'Add Task', extraCss: '' }) %>

    <%- include('../../partials/sidebar.ejs') %>
    <%- include('../../partials/header.ejs') %>

    <!--! Main Content -->
    <main class="nxl-container">
        <div class="nxl-content">
            <!-- Page Header -->
            <div class="page-header">
                <div class="page-header-left d-flex align-items-center">
                    <div class="page-header-title">
                        <h5 class="m-b-10">Add Task</h5>
                    </div>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item"><a href="/admin/viewTasks">Tasks</a></li>
                        <li class="breadcrumb-item">Add Task</li>
                    </ul>
                </div>
                <div class="page-header-right ms-auto">
                    <a href="/admin/viewTasks" class="btn btn-light-brand">
                        <i class="feather-arrow-left me-2"></i>Back to Tasks
                    </a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="main-content">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card stretch stretch-full">
                            <div class="card-header">
                                <h5 class="card-title">Task Information</h5>
                                <p class="text-muted fs-12">Fill in the details below to create a new task</p>
                            </div>
                            <div class="card-body">
                                <form action="/admin/addTask" method="POST">
                                    <div class="mb-4">
                                        <label class="form-label">Task Name <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="feather-file-text"></i></span>
                                            <input type="text" name="name" class="form-control" placeholder="Enter task name" required>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <label class="form-label">Description</label>
                                        <textarea name="description" class="form-control" rows="4" placeholder="Enter task description"></textarea>
                                    </div>
                                    <div class="row mb-4">
                                        <div class="col-lg-6">
                                            <label class="form-label">Assign To <span class="text-danger">*</span></label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="feather-user"></i></span>
                                                <select name="assignedTo" class="form-control" required>
                                                    <option value="">Select Employee</option>
                                                    <% if (typeof employees !== 'undefined' && employees.length > 0) { %>
                                                        <% employees.forEach(emp => { %>
                                                            <option value="<%= emp._id %>"><%= emp.name %> (<%= emp.email %>)</option>
                                                        <% }) %>
                                                    <% } %>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <label class="form-label">Created By</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="feather-shield"></i></span>
                                                <input type="text" class="form-control" value="<%= typeof admin !== 'undefined' && admin ? admin.name : 'Admin' %>" disabled>
                                                <input type="hidden" name="createdby" value="<%= typeof admin !== 'undefined' && admin ? admin.id : '' %>">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-end gap-2 mt-4">
                                        <a href="/admin/viewTasks" class="btn btn-light">Cancel</a>
                                        <button type="submit" class="btn btn-primary">
                                            <i class="feather-plus-square me-2"></i>Create Task
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <footer class="footer">
                <p class="fs-11 text-muted fw-medium text-uppercase mb-0 copyright">
                    <span>Copyright ©</span>
                    <script>document.write(new Date().getFullYear())</script>
                </p>
            </footer>
        </div>
    </main>

<%- include('../../partials/footer.ejs', { extraJs: '' }) %>
