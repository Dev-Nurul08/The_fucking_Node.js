<%- include('../partials/header.ejs') %>
    <!-- ============================================================== -->
    <!-- Page wrapper  -->
    <!-- ============================================================== -->
    <div class="page-wrapper">
        <!-- ============================================================== -->
        <!-- Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <div class="page-breadcrumb">
            <div class="row">
                <div class="col-12 d-flex no-block align-items-center">
                    <h4 class="page-title">Edit Blog</h4>
                    <div class="ml-auto text-right">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/admin">Home</a></li>
                                <li class="breadcrumb-item"><a href="/all-blogs">All Blogs</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Edit</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Bread crumb and right sidebar toggle -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Container fluid  -->
        <!-- ============================================================== -->
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <form class="form-horizontal" method="post" action="/edit-blog/<%= blog._id %>"
                            enctype="multipart/form-data">
                            <div class="card-body">
                                <h4 class="card-title">Edit Blog</h4>
                                <div class="form-group row">
                                    <label for="title" class="col-sm-3 text-right control-label col-form-label">Blog
                                        Title</label>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="title" placeholder="Blog Title Here"
                                            name="title" value="<%= blog.title %>">
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="image" class="col-sm-3 text-right control-label col-form-label">Blog
                                        Image</label>
                                    <div class="col-sm-9">
                                        <input type="file" class="form-control" id="image" placeholder="Select Image"
                                            name="image">
                                        <small class="text-muted">Leave empty to keep current image</small>
                                        <div class="mt-2">
                                            <img src="/<%= blog.image %>" alt="Current image"
                                                style="width: 120px; height: 80px; object-fit: cover; border-radius: 4px;">
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="description"
                                        class="col-sm-3 text-right control-label col-form-label">Description</label>
                                    <div class="col-sm-9">
                                        <textarea class="form-control" rows="5" id="description"
                                            placeholder="Description Here"
                                            name="description"><%= blog.description %></textarea>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="author" class="col-sm-3 text-right control-label col-form-label">Author
                                        Name</label>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="author"
                                            placeholder="Author Name Here" name="author" value="<%= blog.author %>">
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="date"
                                        class="col-sm-3 text-right control-label col-form-label">Date</label>
                                    <div class="col-sm-9">
                                        <input type="date" class="form-control" id="date" name="date"
                                            value="<%= new Date(blog.date).toISOString().split('T')[0] %>">
                                    </div>
                                </div>
                            </div>
                            <div class="border-top">
                                <div class="card-body">
                                    <button type="submit" class="btn btn-primary">Update</button>
                                    <a href="/all-blogs" class="btn btn-secondary ml-2">Cancel</a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- End Container fluid  -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- footer -->
        <!-- ============================================================== -->
        <%- include('../partials/footer.ejs') %>